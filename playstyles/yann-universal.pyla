#  VECTOR / MOVEMENT HELPERS
# О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰

def vec_len(x, y):
    return math.sqrt(x * x + y * y)

def normalize_move(x, y, radius=JOYSTICK_RADIUS):
    length = vec_len(x, y)
    if length <= 0:
        return (0, 0)
    scale = radius / length
    return (x * scale, y * scale)

def is_blocked(move):
    return is_path_blocked(player_data, move, walls)

def first_unblocked(moves, fallback=None):
    for move in moves:
        if not is_blocked(move):
            return move
    if fallback is not None:
        return fallback
    if moves:
        return moves[0]
    return (0, 0)

def move_toward(target_pos):
    dx = target_pos[0] - player_pos[0]
    dy = target_pos[1] - player_pos[1]
    full = normalize_move(dx, dy)
    x_only = normalize_move(dx, 0)
    y_only = normalize_move(0, dy)
    return first_unblocked([full, x_only, y_only], full)

def move_away_from(target_pos):
    dx = player_pos[0] - target_pos[0]
    dy = player_pos[1] - target_pos[1]
    full = normalize_move(dx, dy)
    x_only = normalize_move(dx, 0)
    y_only = normalize_move(0, dy)
    return first_unblocked([full, x_only, y_only], full)

def strafe_around(target_pos):
    dx = target_pos[0] - player_pos[0]
    dy = target_pos[1] - player_pos[1]
    side = 1 if int(time.time() / 2) % 2 == 0 else -1
    sx = -dy * side
    sy = dx * side
    full = normalize_move(sx, sy)
    reverse = normalize_move(-sx, -sy)
    return first_unblocked([full, reverse], full)

# в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ
#  ARCHETYPE DETECTION
# О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰

def detect_archetype():
    ar = float(brawler_info.get("attack_range", attack_range or 400))
    sr = float(brawler_info.get("safe_range", safe_range or 200))
    wall_ignore = brawler_info.get("ignore_walls_for_attacks", False)

    if wall_ignore:
        return "LOBS"
    if ar <= 256:
        return "ASSASSIN"
    if sr == 0.0 and ar <= 350:
        return "TANK"
    if ar >= 600:
        return "SNIPER"
    return "RANGED"

archetype = detect_archetype()


# О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰
#  ATTACK HELPERS
# О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰

def do_attack():
    if not must_hold:
        attack()
        return

    hold_attack_time = float(brawler_info.get("hold_attack", 0.0))

    if persistent_data["time_since_holding_attack"] is None:
        persistent_data["time_since_holding_attack"] = time.time()
        attack(touch_up=False, touch_down=True)

    elif time.time() - persistent_data["time_since_holding_attack"] >= hold_attack_time:
        attack(touch_up=True, touch_down=False)
        persistent_data["time_since_holding_attack"] = None

def try_use_super(enemy_coords, enemy_distance):
    if not is_super_ready:
        return

    if persistent_data["time_since_holding_attack"] is not None:
        return

    super_type = brawler_info.get("super_type", "damage")
    enemy_hittable = is_enemy_hittable(player_pos, enemy_coords, walls, "super")

    should_super = (
        enemy_hittable and (
            enemy_distance <= super_range
            or super_type in ["spawnable", "other"]
            or (
                _brawler_name in ["stu", "surge"]
                and super_type == "charge"
                and enemy_distance <= super_range + attack_range
            )
        )
    )

    if should_super:
        if is_hypercharge_ready:
            use_hypercharge()
        use_super()

def try_attack(enemy_coords, enemy_distance, allow_wall_attack=False):
    if enemy_distance > attack_range:
        return False

    enemy_hittable = is_enemy_hittable(player_pos, enemy_coords, walls, "attack")

    if enemy_hittable or allow_wall_attack:
        if is_gadget_ready and persistent_data["time_since_holding_attack"] is None:
            if time.time() - persistent_data["last_gadget_use"] > 3.0:
                use_gadget()
                persistent_data["last_gadget_use"] = time.time()

        do_attack()
        return True

    return False


