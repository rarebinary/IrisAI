# О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰
#  POISON GAS
# О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰

def avoid_poison_gas():
    poison_gas = is_there_poison_gas(player_data)
    x = 0
    y = 0

    if poison_gas["up"] or poison_gas["down"]:
        if poison_gas["up"] > poison_gas["down"]:
            y = JOYSTICK_RADIUS
        else:
            y = -JOYSTICK_RADIUS

    if poison_gas["left"] or poison_gas["right"]:
        if poison_gas["left"] > poison_gas["right"]:
            x = JOYSTICK_RADIUS
        else:
            x = -JOYSTICK_RADIUS

    if x == 0 and y == 0:
        return None

    move = normalize_move(x, y)
    return first_unblocked([move, (x, 0), (0, y)], move)


# О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰
#  NO ENEMY / EXPLORATION
# О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰

def get_teammate_follow_movement(player_data, teammate_data, walls):
    player_pos = get_entity_pos(player_data)
    closest_teammate, _ = find_closest_teammate(teammate_data, player_pos, walls)
    if closest_teammate is None:
        return None
    return move_toward(closest_teammate)


def get_multi_enemy_spacing_movement(player_data, player_pos, enemy_data, brawler_name, walls):
    if not enemy_data:
        return None

    _, attack_range, _ = get_brawler_range(brawler_name)

    move_x = 0
    move_y = 0
    count = 0

    for enemy in enemy_data:
        enemy_pos = get_entity_pos(enemy)
        dist = get_distance(player_pos, enemy_pos)
        if dist < 1:
            dist = 1

        dx = player_pos[0] - enemy_pos[0]
        dy = player_pos[1] - enemy_pos[1]

        if dist < attack_range * 0.5:
            weight = (attack_range * 0.5 - dist) / (attack_range * 0.5)
            move_x += (dx / dist) * weight * JOYSTICK_RADIUS * 1.5
            move_y += (dy / dist) * weight * JOYSTICK_RADIUS * 1.5
            count += weight
        elif dist < attack_range * 1.5:
            strafe_dir = 1 if int(time.time() * 2) % 2 == 0 else -1
            move_x += (-dy / dist) * JOYSTICK_RADIUS * 0.7 * strafe_dir
            move_y += (dx / dist) * JOYSTICK_RADIUS * 0.7 * strafe_dir
            count += 1

    if count > 0:
        return normalize_move(move_x / count, move_y / count)

    closest_enemy_pos, _ = find_closest_enemy(enemy_data, player_pos, walls, "attack")
    if closest_enemy_pos is not None:
        return move_toward(closest_enemy_pos)

    return None


def no_enemy_movement():
    follow_movement = get_teammate_follow_movement(player_data, teammate_data, walls)
    if follow_movement is not None and (follow_movement[0] != 0 or follow_movement[1] != 0):
        return follow_movement

    forward = (0, -JOYSTICK_RADIUS)
    if not is_blocked(forward):
        return forward

    return (0, -JOYSTICK_RADIUS)


# О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰
#  MAIN BEHAVIOR TREE 
# О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰

enemy_coords = None
enemy_distance = None

# 1. Detectar ameaв”њВєas e alvos
if is_there_enemy(enemy_data):
    enemy_coords, enemy_distance = find_closest_enemy(
        enemy_data, player_pos, walls, "attack"
    )

anti_gas_movement = avoid_poison_gas()

# 2. Reaв”њВєв”њГєo de Fuga do Gв”њГ­s
if anti_gas_movement is not None:
    movement = anti_gas_movement
    
    # Continua atirando mesmo fugindo do gв”њГ­s se houver inimigos
    if enemy_coords is not None:
        try_use_super(enemy_coords, enemy_distance)
        if archetype == "LOBS":
            try_attack(enemy_coords, enemy_distance, allow_wall_attack=True)
        else:
            try_attack(enemy_coords, enemy_distance)

# 3. в”њГјrvore de Combate Padrв”њГєo
else:
    if enemy_coords is None:
        movement = no_enemy_movement()
    else:
        try_use_super(enemy_coords, enemy_distance)
        
        # Ataca SEMPRE que estiver em alcance e com visв”њГєo, independente do movimento
        if archetype == "LOBS":
            try_attack(enemy_coords, enemy_distance, allow_wall_attack=True)
        else:
            try_attack(enemy_coords, enemy_distance)

        movement = get_multi_enemy_spacing_movement(player_data, player_pos, enemy_data, _brawler_name, walls)
        if is_blocked(movement):
            movement = first_unblocked(
                [move_away_from(enemy_coords), strafe_around(enemy_coords)], movement
            )


# О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰
#  FINAL SAFETY
# О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰О“ГІГ‰

if movement is None:
    movement = (0, 0)

if is_path_blocked(player_data, movement, walls):
    movement = (0, -JOYSTICK_RADIUS)
